# Português brasileiro (pt-BR) — sugestões humanas apenas.
# JSON de máquina (`error.message`) e tracing permanecem em inglês (contrato de agente).
# Chaves alinhadas com `Mensagem` em src/i18n/mensagem.rs. Acentuação NFC obrigatória.

usage-suggestion = Confira --help e os argumentos obrigatórios
broken-pipe-suggestion = Não pipe stdout para consumidor fechado; exit 141 é esperado
unavailable-suggestion = Instale Chrome/Chromium no PATH ou use: browser-automation-cli config set chrome_path <path>
data-suggestion = Verifique robots.txt ou o payload JSON/NDJSON
browser-suggestion = Verifique URL e se o Chrome ainda está vivo no one-shot
vision-required = Passe --experimental-vision na mesma invocação
robots-dual = Passe as duas flags juntas quando ignorar robots.txt de propósito
category-memory = Passe --category-memory (heap take/summary/close funcionam sem ops de grafo profundo)
category-extensions = Passe --category-extensions na mesma invocação
screencast-flag = Passe --experimental-screencast na mesma invocação
webmcp-flag = Passe --category-webmcp na mesma invocação
third-party-flag = Passe --category-third-party na mesma invocação
capture-network = Passe --capture-network antes de run/net
capture-console = Passe --capture-console antes de run/console
run-fail-fast = Corrija o passo com falha; os passos seguintes não foram executados
lighthouse-missing = Instale lighthouse ou: browser-automation-cli config set lighthouse_path <path>
locale-resolved = Locale de UI resolvido
locale-source = Fonte da resolução
