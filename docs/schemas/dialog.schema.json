{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/danilo-aguiar-br/browser-automation-cli/docs/schemas/dialog.schema.json",
  "title": "dialog command input",
  "type": "object",
  "description": "Accept or dismiss open dialog",
  "properties": {
    "action": {
      "enum": [
        "accept",
        "dismiss"
      ],
      "type": "string"
    },
    "if_present": {
      "description": "Soft-ok when no dialog is showing (GAP-006); envelope dialog_shown:false",
      "type": "boolean"
    },
    "text": {
      "description": "Optional prompt response text (accept only)",
      "type": "string"
    }
  },
  "required": [
    "action"
  ],
  "additionalProperties": false
}