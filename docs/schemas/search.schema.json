{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/danilo-aguiar-br/browser-automation-cli/docs/schemas/search.schema.json",
  "title": "search command input",
  "type": "object",
  "description": "Local search (HTTP SERP links or URL map)",
  "properties": {
    "limit": {
      "minimum": 1,
      "type": "integer"
    },
    "query": {
      "type": "string"
    }
  },
  "required": [
    "query"
  ],
  "additionalProperties": false
}