{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/danilo-aguiar-br/browser-automation-cli/docs/schemas/webmcp.schema.json",
  "title": "webmcp command input",
  "type": "object",
  "description": "Web surface tools (requires --category-webmcp)",
  "properties": {
    "action": {
      "enum": [
        "list",
        "exec"
      ],
      "type": "string"
    },
    "input": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "url": {
      "type": "string"
    }
  },
  "required": [
    "action"
  ],
  "additionalProperties": false
}