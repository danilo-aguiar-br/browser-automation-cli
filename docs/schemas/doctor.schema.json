{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/danilo-aguiar-br/browser-automation-cli/docs/schemas/doctor.schema.json",
  "title": "doctor command input",
  "type": "object",
  "description": "Diagnose local Chrome install and one-shot readiness",
  "properties": {
    "fix": {
      "description": "Apply safe repairs when possible",
      "type": "boolean"
    },
    "json": {
      "type": "boolean"
    },
    "offline": {
      "description": "Skip network probes",
      "type": "boolean"
    },
    "quick": {
      "description": "Skip live launch test",
      "type": "boolean"
    }
  },
  "required": [],
  "additionalProperties": false
}